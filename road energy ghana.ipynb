# ============================================================
# THE MODEL: Kinetic Energy → kWh → Homes Powered
# ============================================================
# Physics: KE = ½mv² (in Joules)
# We assume each vehicle makes ~2 trips/day, ~25 km per trip
# Efficiency factor: 25% (regenerative braking / energy capture)
# Road quality adjusts effective speed

EFFICIENCY = 0.25          # 25% energy capture
TRIPS_PER_DAY = 2          # Average trips per vehicle per day
KM_PER_TRIP = 25           # Average distance per trip
DAYS_PER_MONTH = 30        # Days in a month
JOULES_TO_KWH = 3_600_000  # 1 kWh = 3.6 million Joules

# Step 1: Convert speed to m/s and apply road quality factor
df['Speed_ms'] = (df['Avg_Speed_kmh'] / 3.6) * df['Road_Quality_Factor']

# Step 2: Kinetic Energy per vehicle (Joules)
df['KE_Joules'] = 0.5 * df['Avg_Mass_kg'] * (df['Speed_ms'] ** 2)

# Step 3: Total daily energy per region (Joules)
df['Daily_Energy_J'] = df['KE_Joules'] * df['Vehicle_Count'] * TRIPS_PER_DAY * KM_PER_TRIP * EFFICIENCY

# Step 4: Monthly energy in kWh
df['Monthly_kWh'] = (df['Daily_Energy_J'] * DAYS_PER_MONTH) / JOULES_TO_KWH

# Step 5: Homes powered per region
df['Homes_Powered'] = (df['Monthly_kWh'] / df['Household_kWh_Month']).astype(int)

print("✅ Model complete!")
print(f"\n⚡ Total monthly energy potential: {df['Monthly_kWh'].sum():,.0f} kWh")
print(f"🏠 Total homes that could be powered: {df['Homes_Powered'].sum():,}")
